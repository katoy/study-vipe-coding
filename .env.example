# Example environment variables for running the app
# Allow origins is a comma-separated list. In production, avoid '*'.
# Example (development):
# ALLOW_ORIGINS=http://localhost:8000
# Example (production):
# ALLOW_ORIGINS=https://app.example.com,https://admin.example.com

# CORS
ALLOW_ORIGINS=http://localhost:8000

# Enable power operator (べき乗). Default 0 (disabled). Set to 1 to enable.
ALLOW_POW=0

# Rate limit for /api/ endpoints (requests per minute). Default 60.
RATE_LIMIT_PER_MIN=60