<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>計算機</title>
  <link rel="icon" href="/static/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0d0f14;
      --card: #161820;
      --card-border: rgba(255,255,255,0.06);
      --display-bg: #0a0b0f;
      --display-text: #f0f4ff;
      --display-muted: #4a5068;
      --btn-num: #1e2130;
      --btn-num-hover: #252840;
      --btn-num-text: #e2e8f0;
      --btn-op: #1e2c4a;
      --btn-op-hover: #253460;
      --btn-op-text: #7ea8f8;
      --btn-eq: #3563e9;
      --btn-eq-hover: #4070f5;
      --btn-eq-text: #fff;
      --btn-clr: #2d1a1a;
      --btn-clr-hover: #3a2020;
      --btn-clr-text: #f87171;
      --btn-del: #1e2130;
      --btn-del-hover: #252840;
      --btn-del-text: #94a3b8;
      --text: #e2e8f0;
      --muted: #4a5068;
      --accent: #3563e9;
      --danger: #f87171;
      --radius-card: 20px;
      --radius-btn: 12px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    .calculator {
      background: var(--card);
      border: 1px solid var(--card-border);
      border-radius: var(--radius-card);
      padding: 24px;
      width: 360px;
      box-shadow: 0 24px 48px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.03);
    }

    /* Display */
    .display {
      background: var(--display-bg);
      border-radius: 12px;
      padding: 20px 20px 16px;
      margin-bottom: 16px;
      min-height: 80px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: flex-end;
      border: 1px solid rgba(255,255,255,0.04);
    }

    .display input {
      width: 100%;
      background: transparent;
      border: none;
      color: var(--display-text);
      font-family: 'DM Mono', monospace;
      font-size: 2rem;
      font-weight: 400;
      text-align: right;
      outline: none;
      caret-color: var(--accent);
      letter-spacing: -0.5px;
    }

    .display input::placeholder {
      color: var(--display-muted);
      font-size: 1.2rem;
    }

    /* Fraction preview */
    #fraction-preview {
      min-height: 20px;
      text-align: right;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .fraction {
      display: inline-flex;
      flex-direction: row;
      align-items: center;
      justify-content: flex-end;
      color: var(--display-muted);
      font-family: 'DM Mono', monospace;
      font-size: 0.8rem;
    }
    .fraction .whole { margin-right: 8px; }
    .fraction .stack { display: inline-flex; flex-direction: column; align-items: center; }
    .fraction .num, .fraction .den { padding: 0 4px; text-align: center; }
    .fraction .bar { border-top: 1px solid var(--display-muted); width: 100%; min-width: 24px; margin: 1px 0; }

    /* Result */
    .result {
      text-align: right;
      font-family: 'DM Mono', monospace;
      font-size: 0.82rem;
      min-height: 18px;
      color: var(--danger);
      font-weight: 500;
      margin-top: 4px;
    }

    /* Hint */
    .hint {
      font-size: 0.78rem;
      color: var(--muted);
      margin-bottom: 10px;
      padding-left: 2px;
    }

    /* Curly brace row */
    .extras {
      display: flex;
      gap: 6px;
      margin-bottom: 12px;
    }

    /* Buttons grid */
    .buttons {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }

    button {
      height: 56px;
      border: none;
      border-radius: var(--radius-btn);
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.12s ease, transform 0.08s ease, opacity 0.1s;
      display: flex;
      align-items: center;
      justify-content: center;
      -webkit-tap-highlight-color: transparent;
      letter-spacing: -0.2px;
    }

    button:active {
      transform: scale(0.94);
      opacity: 0.85;
    }

    button:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    /* Button types */
    .btn-num {
      background: var(--btn-num);
      color: var(--btn-num-text);
    }
    .btn-num:hover { background: var(--btn-num-hover); }

    .btn-op {
      background: var(--btn-op);
      color: var(--btn-op-text);
      font-size: 1.1rem;
    }
    .btn-op:hover { background: var(--btn-op-hover); }

    .btn-eq {
      background: var(--btn-eq);
      color: var(--btn-eq-text);
      font-size: 1.2rem;
    }
    .btn-eq:hover { background: var(--btn-eq-hover); }

    .btn-clr {
      background: var(--btn-clr);
      color: var(--btn-clr-text);
    }
    .btn-clr:hover { background: var(--btn-clr-hover); }

    .btn-del {
      background: var(--btn-del);
      color: var(--btn-del-text);
    }
    .btn-del:hover { background: var(--btn-del-hover); }

    .btn-span2 { grid-column: span 2; }

    .btn-extra {
      height: 32px;
      padding: 0 12px;
      font-size: 0.88rem;
      border-radius: 8px;
      background: var(--btn-num);
      color: var(--muted);
    }
    .btn-extra:hover { background: var(--btn-num-hover); color: var(--btn-num-text); }

    .visually-hidden {
      position: absolute !important;
      height: 1px; width: 1px;
      overflow: hidden;
      clip: rect(1px,1px,1px,1px);
      white-space: nowrap;
    }
  </style>
</head>
<body>
<div class="calculator" role="main">
  <form id="calc-form" role="form" aria-label="計算機フォーム"
        hx-post="/calculate" hx-target="#result" hx-swap="outerHTML"
        method="post" novalidate>

    <div class="display">
      <input type="text" name="expression" id="expression"
             value="{{ value if value is not none else expression or '' }}"
             aria-label="式入力" placeholder="0"
             autocomplete="off" spellcheck="false" />
      <div id="fraction-preview"><!-- HTMX OOB --></div>
    </div>

    <div class="result" id="result" role="status" aria-live="polite" aria-atomic="true">
      {% if result %}{{ result }}{% endif %}
    </div>

    <div class="hint">循環小数は 0.{3} と入力</div>

    <div class="extras">
      <button type="button" class="btn-extra" aria-label="左波括弧" onclick="appendToExpr('{')">{</button>
      <button type="button" class="btn-extra" aria-label="右波括弧" onclick="appendToExpr('}')">}</button>
    </div>

    <div class="buttons">
      <button class="btn-clr btn-span2" type="button" aria-label="全消去"
              onclick="document.getElementById('expression').value='';document.getElementById('result').textContent='';">AC</button>
      <button class="btn-op" type="button" aria-label="パーセント" onclick="appendToExpr('%')">%</button>
      <button class="btn-op" type="button" aria-label="割り算" onclick="appendToExpr('/')">÷</button>

      <button class="btn-num" type="button" aria-label="7" onclick="appendToExpr('7')">7</button>
      <button class="btn-num" type="button" aria-label="8" onclick="appendToExpr('8')">8</button>
      <button class="btn-num" type="button" aria-label="9" onclick="appendToExpr('9')">9</button>
      <button class="btn-op" type="button" aria-label="掛け算" onclick="appendToExpr('*')">×</button>

      <button class="btn-num" type="button" aria-label="4" onclick="appendToExpr('4')">4</button>
      <button class="btn-num" type="button" aria-label="5" onclick="appendToExpr('5')">5</button>
      <button class="btn-num" type="button" aria-label="6" onclick="appendToExpr('6')">6</button>
      <button class="btn-op" type="button" aria-label="引き算" onclick="appendToExpr('-')">−</button>

      <button class="btn-num" type="button" aria-label="1" onclick="appendToExpr('1')">1</button>
      <button class="btn-num" type="button" aria-label="2" onclick="appendToExpr('2')">2</button>
      <button class="btn-num" type="button" aria-label="3" onclick="appendToExpr('3')">3</button>
      <button class="btn-op" type="button" aria-label="足し算" onclick="appendToExpr('+')">+</button>

      <button class="btn-num" type="button" aria-label="0" onclick="appendToExpr('0')">0</button>
      <button class="btn-del" type="button" aria-label="一文字削除" onclick="deleteLastChar()">⌫</button>
      <button class="btn-num" type="button" aria-label="小数点" onclick="appendToExpr('.')">.</button>
      <button class="btn-eq" type="submit" aria-label="計算実行">=</button>
    </div>
  </form>
</div>

<script src="/static/htmx.min.js"></script>
<script>
function appendToExpr(val) {
  const input = document.getElementById('expression');
  input.value += val;
  input.focus();
}
function deleteLastChar() {
  const input = document.getElementById('expression');
  if (!input.value) return;
  input.value = input.value.slice(0, -1);
  input.focus();
}

function convertRepeatingNotation(expr) {
  const re = /(-?)(\d*)\.(\d*)(?:\((\d+)\)|\{(\d+)\})/g;
  return expr.replace(re, function(_, sign, whole, nonrep, rep1, rep2) {
    const rep = rep1 || rep2;
    const W = whole ? BigInt(whole) : 0n;
    const A = nonrep || '';
    const B = rep;
    const mlen = A.length;
    const nlen = B.length;
    const ten = (n) => 10n ** BigInt(n);
    let num, den;
    if (mlen > 0) {
      num = BigInt(A) * (ten(nlen) - 1n) + BigInt(B);
      den = ten(mlen) * (ten(nlen) - 1n);
    } else {
      num = BigInt(B);
      den = ten(nlen) - 1n;
    }
    let total = W * den + num;
    if (sign === '-') total = -total;
    return `(${total.toString()}/${den.toString()})`;
  });
}

const form = document.getElementById('calc-form');
if (form) {
  form.addEventListener('submit', function() {
    const input = document.getElementById('expression');
    if (input && input.value) {
      input.value = convertRepeatingNotation(input.value);
    }
  });
}
</script>
</body>
</html>
